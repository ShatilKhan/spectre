backend -> chroma: "embed & query"
backend -> ollama: "GPU inference\n(auto-detect)"
backend -> cpu_backend: "CPU fallback"
backend -> jaeger: "OTLP gRPC\n(port 4317)"
backend -> cuad: "benchmark\nclauses + PDFs"
pdfs -> backend: "OCR pipeline"

# █████████████████████████████████████████████████████████████████████
#  Spectre — Environment Configuration
#  Copy to .env and adjust for your environment:
#    cp .env.example .env
# █████████████████████████████████████████████████████████████████████

# ── LLM Backend ──────────────────────────────────────────────────────

# Ollama host URL (GPU path). Leave empty to use CPU fallback.
# With Docker: use host.docker.internal to reach host's Ollama.
# Without Docker: use http://localhost:11434
OLLAMA_BASE_URL=http://host.docker.internal:11434

# GGUF model path for CPU fallback (llama-cpp-python).
# Auto-downloaded on container start if missing.
MODEL_PATH=/models/ibm-granite_granite-4.1-3b-Q4_K_M.gguf

# ── Database ─────────────────────────────────────────────────────────

DATABASE_URL=sqlite:////home/user/app/data/spectre.db
CHROMA_PERSIST_DIR=/home/user/app/data/chroma

# ── Telemetry / Tracing (Jaeger) ─────────────────────────────────────

# Set this to the Jaeger OTLP gRPC endpoint to enable tracing.
# Leave empty to disable tracing (app runs without Jaeger).
# With Docker Compose: http://jaeger:4317
# Standalone Jaeger:    http://localhost:4317
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317

# Service name shown in Jaeger traces
OTEL_SERVICE_NAME=spectre-backend

# ── Frontend ─────────────────────────────────────────────────────────

# Backend URL the frontend connects to (Docker internal or localhost)
API_BASE_URL=http://backend:8000

# ── Docker Volumes (paths relative to project root) ──────────────────

# These are hard-coded in docker-compose.yml; listed here for reference.
# - ./models        → GGUF model files
# - ./data          → SQLite DB + ChromaDB persistence
# - ./sample_docs   → PDF documents for testing
# - ./datasets      → CUAD evaluation data
# - ./paddlex_cache → PaddleOCR model cache (~/.paddlex)
